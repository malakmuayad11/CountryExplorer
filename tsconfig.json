{
  "compilerOptions": {
    "rootDir": "./src/js",
    "outDir": "./dist/js",

    "module": "esnext",
    "target": "es2020",
    "types": [],
    "lib": ["ES2020", "DOM"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
